---
import { metrics } from '../data/profile';
---

<section class="metrics">
  <div class="container metrics__grid">
    {
      metrics.map((m) => (
        <div class="metrics__item reveal">
          <span class="metrics__value">{m.value}</span>
          <span class="metrics__label">{m.label}</span>
        </div>
      ))
    }
  </div>
</section>

<style>
  .metrics {
    background: var(--bg-alt);
    border-top: 1px solid var(--border-soft);
    border-bottom: 1px solid var(--border-soft);
    padding-block: clamp(40px, 7vw, 72px);
  }

  .metrics__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px 20px;
  }

  @media (min-width: 720px) {
    .metrics__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .metrics__grid {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  .metrics__item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .metrics__value {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 36px);
    font-weight: 700;
    color: var(--accent-bright);
  }

  .metrics__label {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.4;
  }
</style>
