---
import { person } from '../data/profile';

const [taglineBefore, taglineAfter] = person.tagline.split('—');
---

<section class="hero">
  <div class="hero__glow" aria-hidden="true"></div>
  <div class="container hero__inner" id="hero-inner">
    <img
      class="hero__photo reveal"
      src="/jules-avila.jpg"
      alt={`Portrait of ${person.name}`}
      width="200"
      height="200"
    />
    <div class="hero__content">
      <p class="eyebrow reveal">Hi, I'm</p>
      <h1 class="hero__name reveal">{person.name}</h1>
      <p class="hero__title reveal">{person.title}</p>
      <p class="hero__tagline reveal" id="hero-tagline">
        {taglineBefore}<span class="dash-anchor" id="dash-anchor">—</span>{taglineAfter}
      </p>
      <div class="hero__actions reveal">
        <a class="btn btn-primary" href={`mailto:${person.email}`}>Say hello</a>
        <a class="btn btn-ghost" href={person.links.linkedin} target="_blank" rel="noopener noreferrer">
          LinkedIn
        </a>
      </div>
    </div>

    <div class="dash-note" id="dash-note">
      <span class="dash-note__text">relax — it's an em dash, not a confession.</span>
      <span class="dash-note__secret">psst — 100% AI-written, from my extended virtual memory.</span>
    </div>

    <svg class="dash-connector" id="dash-connector" aria-hidden="true">
      <defs>
        <marker id="dash-arrowhead" viewBox="0 0 10 10" refX="7" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
          <path d="M0,0 L10,5 L0,10 z" fill="currentColor"></path>
        </marker>
      </defs>
      <path id="dash-connector-path" d="" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" marker-end="url(#dash-arrowhead)"></path>
    </svg>
  </div>
</section>

<script>
  // In some embedded/automated browser contexts (extension content
  // scripts, preview iframes), `window.innerWidth` / `documentElement.
  // clientWidth` can report 0 for a while even after `load` and
  // `fonts.ready` — on an already fully-painted, visible page. A 0 is
  // never a real viewport width, so we treat it as "not measured yet"
  // and retry on the next animation frame instead of concluding "narrow,
  // hide" from a bogus reading with nothing left to correct it.
  let viewportWidth = 0;
  let widthRetries = 0;

  function measureViewportWidth() {
    return document.documentElement.clientWidth || window.innerWidth || 0;
  }

  function layoutDashNote() {
    const container = document.getElementById('hero-inner');
    const dash = document.getElementById('dash-anchor');
    const note = document.getElementById('dash-note');
    const svg = document.getElementById('dash-connector') as SVGSVGElement | null;
    const path = document.getElementById('dash-connector-path');
    const tagline = document.getElementById('hero-tagline');
    const heroSection = document.querySelector('.hero');
    const actions = document.querySelector('.hero__actions');
    if (!container || !dash || !note || !svg || !path || !tagline || !heroSection || !actions) return;

    const hide = () => {
      note.style.display = 'none';
      svg.style.display = 'none';
    };

    viewportWidth = measureViewportWidth();

    if (viewportWidth === 0 && widthRetries < 30) {
      widthRetries += 1;
      requestAnimationFrame(layoutDashNote);
      return;
    }

    if (viewportWidth < 900) {
      hide();
      return;
    }

    const containerRect = container.getBoundingClientRect();
    const dashRect = dash.getBoundingClientRect();
    const taglineRect = tagline.getBoundingClientRect();
    const heroRect = heroSection.getBoundingClientRect();
    const actionsRect = actions.getBoundingClientRect();

    const dashX = dashRect.right - containerRect.left;
    const dashY = dashRect.top + dashRect.height / 2 - containerRect.top;
    const taglineLeft = taglineRect.left - containerRect.left;
    const actionsBottom = actionsRect.bottom - containerRect.top;
    const maxBottom = heroRect.bottom - containerRect.top - 8;

    note.style.maxWidth = '230px';
    note.style.display = 'block';

    const noteWidth = note.offsetWidth;
    const noteHeight = note.offsetHeight;

    if (actionsBottom + noteHeight + 16 > maxBottom) {
      hide();
      return;
    }

    const noteLeft = Math.max(taglineLeft, containerRect.width - noteWidth - 8);
    const noteTop = actionsBottom + 16;

    note.style.left = `${noteLeft}px`;
    note.style.top = `${noteTop}px`;

    const startX = noteLeft + noteWidth - 24;
    const startY = noteTop - 2;
    const endX = dashX + 4;
    const endY = dashY;
    const midX = (startX + endX) / 2 + 20;
    const midY = (startY + endY) / 2;

    path.setAttribute('d', `M ${startX} ${startY} Q ${midX} ${midY}, ${endX} ${endY}`);

    svg.style.width = `${containerRect.width}px`;
    svg.style.height = `${containerRect.height}px`;
    svg.setAttribute('viewBox', `0 0 ${containerRect.width} ${containerRect.height}`);
    svg.style.display = 'block';

    // Visible immediately in the DOM/opacity sense — the actual 5s
    // delay before anyone sees it is a CSS transition-delay (below),
    // not a JS timer, since JS timers can be throttled indefinitely
    // in backgrounded tabs while CSS transitions are not.
    note.classList.add('is-visible');
    svg.classList.add('is-visible');
  }

  let resizeTimer: ReturnType<typeof setTimeout>;
  function scheduleLayout() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(layoutDashNote, 100);
  }

  function initDashNote() {
    layoutDashNote();
    window.addEventListener('load', layoutDashNote);

    // The initial pass can also measure the note before its hand-drawn
    // font (Caveat) has actually painted, under-or-over-estimating its
    // height. `fonts.ready` is the correct, standard signal for "every
    // font this page references has finished loading" — far more
    // reliable than guessing specific font strings or a blind timer.
    if ('fonts' in document) {
      (document as any).fonts.ready.then(layoutDashNote).catch(() => {});
    }

    // Re-run on any later layout shift — a real window resize, image
    // decode, or a late-swapping webfont. layoutDashNote() re-measures
    // the width itself each time, so this observer only needs to trigger it.
    if ('ResizeObserver' in window) {
      const observer = new ResizeObserver(() => scheduleLayout());
      observer.observe(document.documentElement);

      const container = document.getElementById('hero-inner');
      if (container) observer.observe(container);
    } else {
      window.addEventListener('resize', scheduleLayout);
    }
  }

  initDashNote();
</script>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(64px, 14vw, 140px) clamp(48px, 8vw, 96px);
  }

  .hero__glow {
    position: absolute;
    inset: -20% -10% auto -10%;
    height: 60%;
    background: radial-gradient(
      60% 60% at 30% 20%,
      color-mix(in srgb, var(--melon) 35%, transparent),
      transparent 70%
    );
    filter: blur(10px);
    pointer-events: none;
    z-index: -1;
  }

  .hero__inner {
    position: relative;
    max-width: 840px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 28px;
  }

  .hero__photo {
    width: 104px;
    height: 104px;
    border-radius: 50%;
    object-fit: cover;
    padding: 4px;
    background: linear-gradient(135deg, var(--accent-bright), var(--melon));
    box-shadow: var(--shadow-lift);
  }

  .hero__content {
    max-width: 620px;
  }

  @media (min-width: 760px) {
    .hero__inner {
      flex-direction: row;
      align-items: center;
      gap: 44px;
    }

    .hero__photo {
      width: 168px;
      height: 168px;
      flex-shrink: 0;
      order: 2;
    }

    .hero__content {
      order: 1;
    }
  }

  .hero__name {
    font-size: clamp(40px, 9vw, 76px);
    letter-spacing: -0.02em;
    margin-top: 8px;
  }

  .hero__title {
    font-family: var(--font-mono);
    font-size: clamp(12px, 2vw, 14px);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: 14px;
    font-weight: 500;
  }

  .hero__tagline {
    font-size: clamp(17px, 2.4vw, 21px);
    color: var(--text);
    line-height: 1.6;
    margin-top: 20px;
    max-width: 56ch;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
  }

  .dash-anchor {
    color: var(--accent-bright);
    font-weight: 700;
  }

  .dash-note {
    display: none;
    position: absolute;
    color: var(--cocoa);
    pointer-events: none;
    z-index: 2;
    opacity: 0;
    transition: opacity 1.2s ease 5s;
  }

  .dash-note.is-visible {
    opacity: 1;
  }

  .dash-note__text {
    display: block;
    font-family: var(--font-hand);
    font-weight: 700;
    font-size: 19px;
    line-height: 1.25;
    transform: rotate(-2deg);
  }

  .dash-note__secret {
    display: block;
    margin-top: 2px;
    font-family: var(--font-hand);
    font-size: 11px;
    font-weight: 600;
    line-height: 1.2;
    color: var(--text-muted);
    opacity: 0.4;
    transform: rotate(1deg);
  }

  .dash-connector {
    display: none;
    position: absolute;
    top: 0;
    left: 0;
    color: var(--ash);
    pointer-events: none;
    z-index: 1;
    overflow: visible;
    opacity: 0;
    transition: opacity 1.2s ease 5s;
  }

  .dash-connector.is-visible {
    opacity: 1;
  }
</style>
