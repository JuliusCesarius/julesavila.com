---
import { person } from '../data/profile';

const [taglineBefore, taglineAfter] = person.tagline.split('—');
---

<section class="hero">
  <div class="hero__glow" aria-hidden="true"></div>
  <div class="container">
    <div class="hero__inner">
      <img
        class="hero__photo reveal"
        src="/jules-avila.jpg"
        alt={`Portrait of ${person.name}`}
        width="200"
        height="200"
      />
      <div class="hero__content">
        <p class="eyebrow reveal">Hi, I'm</p>
        <h1 class="hero__name reveal">{person.name}</h1>
        <p class="hero__title reveal">{person.title}</p>
        <p class="hero__tagline reveal">
          {taglineBefore}<span class="dash-anchor">—</span>{taglineAfter}
        </p>
        <div class="hero__actions reveal">
          <a class="btn btn-primary" href={`mailto:${person.email}`}>Say hello</a>
          <a class="btn btn-ghost" href={person.links.linkedin} target="_blank" rel="noopener noreferrer">
            LinkedIn
          </a>
        </div>
      </div>
    </div>

    <p class="dash-note">
      <span class="dash-note__text">relax — it's an em dash, not a confession.</span>
      <span class="dash-note__secret">psst — 100% AI-written, from my extended virtual memory.</span>
    </p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(64px, 14vw, 140px) clamp(48px, 8vw, 96px);
  }

  .hero__glow {
    position: absolute;
    inset: -20% -10% auto -10%;
    height: 60%;
    background: radial-gradient(
      60% 60% at 30% 20%,
      color-mix(in srgb, var(--melon) 35%, transparent),
      transparent 70%
    );
    filter: blur(10px);
    pointer-events: none;
    z-index: -1;
  }

  .hero__inner {
    max-width: 840px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 28px;
  }

  .hero__photo {
    width: 104px;
    height: 104px;
    border-radius: 50%;
    object-fit: cover;
    padding: 4px;
    background: linear-gradient(135deg, var(--accent-bright), var(--melon));
    box-shadow: var(--shadow-lift);
  }

  .hero__content {
    max-width: 620px;
  }

  @media (min-width: 760px) {
    .hero__inner {
      flex-direction: row;
      align-items: center;
      gap: 44px;
    }

    .hero__photo {
      width: 168px;
      height: 168px;
      flex-shrink: 0;
      order: 2;
    }

    .hero__content {
      order: 1;
    }
  }

  .hero__name {
    font-size: clamp(40px, 9vw, 76px);
    letter-spacing: -0.02em;
    margin-top: 8px;
  }

  .hero__title {
    font-family: var(--font-mono);
    font-size: clamp(12px, 2vw, 14px);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: 14px;
    font-weight: 500;
  }

  .hero__tagline {
    font-size: clamp(17px, 2.4vw, 21px);
    color: var(--text);
    line-height: 1.6;
    margin-top: 20px;
    max-width: 56ch;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
  }

  .dash-anchor {
    color: var(--accent-bright);
    font-weight: 700;
  }

  .dash-note {
    margin-top: 20px;
    max-width: 320px;
    color: var(--cocoa);
    opacity: 0;
    animation: dash-note-in 1.2s ease 5s forwards;
  }

  @keyframes dash-note-in {
    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .dash-note {
      animation: none;
      opacity: 1;
    }
  }

  .dash-note__text {
    display: block;
    font-family: var(--font-hand);
    font-weight: 700;
    font-size: 19px;
    line-height: 1.25;
    transform: rotate(-2deg);
  }

  .dash-note__secret {
    display: block;
    margin-top: 2px;
    font-family: var(--font-hand);
    font-size: 11px;
    font-weight: 600;
    line-height: 1.2;
    color: var(--text-muted);
    opacity: 0.4;
    transform: rotate(1deg);
  }
</style>
