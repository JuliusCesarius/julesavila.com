---
import { caseStudies } from '../data/profile';
---

<section id="work" class="work">
  <div class="container">
    <p class="eyebrow reveal">Selected work</p>
    <h2 class="section-heading reveal">Problems worth telling stories about</h2>
    <p class="section-lede reveal">Three moments where the diagnosis mattered as much as the fix.</p>

    <div class="work__grid">
      {
        caseStudies.map((c) => (
          <details class="work__card reveal">
            <summary>
              <span class="work__company eyebrow">{c.company}</span>
              <span class="work__title">{c.title}</span>
              <span class="work__chevron" aria-hidden="true">＋</span>
            </summary>
            <div class="work__body">
              <p><strong>Problem.</strong> {c.problem}</p>
              <p><strong>Solution.</strong> {c.solution}</p>
              <ul class="work__impact">
                {c.impact.map((i) => (
                  <li>{i}</li>
                ))}
              </ul>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .work__grid {
    margin-top: 36px;
    display: grid;
    gap: 16px;
  }

  .work__card {
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-m);
    padding: 4px;
    transition: border-color 0.15s ease;
  }

  .work__card[open] {
    border-color: var(--accent-glow);
  }

  .work__card summary {
    list-style: none;
    cursor: pointer;
    padding: 18px 20px;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .work__card summary::-webkit-details-marker {
    display: none;
  }

  .work__company {
    flex-shrink: 0;
  }

  .work__title {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 600;
    color: var(--text-strong);
    flex: 1;
  }

  .work__chevron {
    font-size: 18px;
    color: var(--accent);
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  .work__card[open] .work__chevron {
    transform: rotate(45deg);
  }

  .work__body {
    padding: 0 20px 22px 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .work__body p {
    font-size: 14.5px;
    line-height: 1.7;
    color: var(--text);
  }

  .work__body strong {
    color: var(--text-strong);
  }

  .work__impact {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }

  .work__impact li {
    font-size: 12.5px;
    font-weight: 600;
    color: var(--accent);
    background: var(--mist);
    border-radius: 999px;
    padding: 6px 12px;
  }

  @media (max-width: 560px) {
    .work__card summary {
      flex-wrap: wrap;
    }
    .work__title {
      order: 3;
      flex-basis: 100%;
    }
  }
</style>
