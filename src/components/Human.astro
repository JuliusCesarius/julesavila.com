---
import { philosophy } from '../data/profile';
---

<section id="about" class="human">
  <div class="container">
    <p class="eyebrow reveal">{philosophy.eyebrow}</p>
    <h2 class="section-heading reveal">{philosophy.heading}</h2>

    <div class="human__grid">
      <ul class="human__quotes reveal">
        {philosophy.quotes.map((q) => <li>{q}</li>)}
      </ul>

      <div class="human__side reveal">
        <p class="human__mantra">"{philosophy.mantra}"</p>
        <div class="human__hobbies">
          <span class="human__hobbies-label">Off the clock</span>
          <div class="human__tags">
            {philosophy.hobbies.map((h) => <span class="human__tag">{h}</span>)}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .human__grid {
    margin-top: 36px;
    display: grid;
    gap: 32px;
  }

  @media (min-width: 800px) {
    .human__grid {
      grid-template-columns: 1.2fr 1fr;
      gap: 48px;
    }
  }

  .human__quotes {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .human__quotes li {
    font-family: var(--font-display);
    font-size: clamp(17px, 2.2vw, 21px);
    font-style: italic;
    line-height: 1.5;
    color: var(--text-strong);
    padding-left: 20px;
    border-left: 3px solid var(--accent-glow);
  }

  .human__side {
    background: var(--mist);
    border-radius: var(--radius-l);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    height: fit-content;
  }

  .human__mantra {
    font-size: 14.5px;
    line-height: 1.7;
    color: var(--cocoa);
    font-weight: 500;
  }

  .human__hobbies-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .human__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 10px;
  }

  .human__tag {
    font-size: 12.5px;
    font-weight: 600;
    color: var(--cocoa);
    background: var(--surface);
    border-radius: 999px;
    padding: 6px 12px;
  }
</style>
