---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import {
  person,
  jobs,
  earlier,
  education,
  certifications,
  languages,
} from '../data/profile';
---

<Base title={`${person.name} — Resume`} description={`${person.title}. Downloadable resume.`}>
  <Nav />
  <main class="resume">
    <div class="container resume__container">
      <div class="resume__toolbar">
        <a class="btn btn-primary" href="/resume-jules-avila.pdf" download>Download PDF</a>
        <a class="btn btn-ghost" href={`mailto:${person.email}`}>Email me</a>
      </div>

      <article class="resume__doc">
        <header class="resume__header">
          <div>
            <h1 class="resume__name">{person.name}</h1>
            <p class="resume__title">{person.title}</p>
          </div>
          <div class="resume__contact">
            <a href={`mailto:${person.email}`}>{person.email}</a>
            <a href={person.links.linkedin} target="_blank" rel="noopener noreferrer">linkedin.com/in/jules-avila</a>
            <a href={person.links.github} target="_blank" rel="noopener noreferrer">github.com/JuliusCesarius</a>
          </div>
        </header>

        <section class="resume__section">
          <h2>Experience</h2>
          {
            jobs.map((job) => (
              <div class="resume__job">
                <div class="resume__job-header">
                  <span class="resume__job-title">{job.title}</span>
                  <span class="resume__job-period">{job.period}</span>
                </div>
                <p class="resume__job-company">
                  {job.company} — {job.region}
                </p>
                <ul>
                  {job.bullets.map((b) => (
                    <li>{b}</li>
                  ))}
                </ul>
              </div>
            ))
          }

          <div class="resume__job resume__job--earlier">
            <div class="resume__job-header">
              <span class="resume__job-title">{earlier.title}</span>
              <span class="resume__job-period">{earlier.period}</span>
            </div>
            <p class="resume__job-company">{earlier.companies}</p>
            <p class="resume__earlier-body">{earlier.body}</p>
          </div>
        </section>

        <section class="resume__section resume__grid">
          <div>
            <h2>Education</h2>
            {
              education.map((e) => (
                <div class="resume__edu">
                  <span class="resume__edu-degree">{e.degree}</span>
                  <span class="resume__edu-school">
                    {e.school} · {e.year}
                  </span>
                </div>
              ))
            }
          </div>
          <div>
            <h2>Certifications</h2>
            <ul class="resume__plain-list">
              {certifications.map((c) => <li>{c}</li>)}
            </ul>
          </div>
          <div>
            <h2>Languages</h2>
            <ul class="resume__plain-list">
              {languages.map((l) => (
                <li>
                  {l.name} — {l.level}
                </li>
              ))}
            </ul>
          </div>
        </section>
      </article>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .resume {
    padding-block: 40px clamp(48px, 8vw, 96px);
  }

  .resume__container {
    max-width: 820px;
  }

  .resume__toolbar {
    display: flex;
    gap: 12px;
    margin-bottom: 24px;
  }

  .resume__doc {
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-l);
    padding: clamp(28px, 6vw, 56px);
    box-shadow: var(--shadow-soft);
  }

  .resume__header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 16px;
    border-bottom: 2px solid var(--cocoa);
    padding-bottom: 20px;
    margin-bottom: 28px;
  }

  .resume__name {
    font-size: clamp(28px, 4vw, 36px);
  }

  .resume__title {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: 6px;
  }

  .resume__contact {
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .resume__contact a {
    text-decoration: none;
    color: var(--text-muted);
  }

  .resume__contact a:hover {
    color: var(--accent);
  }

  .resume__section {
    margin-bottom: 30px;
  }

  .resume__section h2 {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    font-family: var(--font-body);
    font-weight: 700;
    border-bottom: 1px solid var(--border-soft);
    padding-bottom: 6px;
    margin-bottom: 16px;
  }

  .resume__job {
    margin-bottom: 22px;
  }

  .resume__job:last-child {
    margin-bottom: 0;
  }

  .resume__job-header {
    display: flex;
    justify-content: space-between;
    gap: 12px;
  }

  .resume__job-title {
    font-weight: 600;
    color: var(--text-strong);
    font-size: 14.5px;
  }

  .resume__job-period {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .resume__job-company {
    font-size: 12.5px;
    color: var(--accent);
    font-weight: 500;
    margin-top: 2px;
    margin-bottom: 8px;
  }

  .resume__job ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .resume__job li {
    font-size: 13px;
    line-height: 1.6;
    color: var(--text);
    padding-left: 14px;
    position: relative;
  }

  .resume__job li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--rose);
  }

  .resume__earlier-body {
    font-size: 12.5px;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .resume__grid {
    display: grid;
    gap: 24px;
  }

  @media (min-width: 640px) {
    .resume__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .resume__edu {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-bottom: 10px;
  }

  .resume__edu-degree {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-strong);
  }

  .resume__edu-school {
    font-size: 12px;
    color: var(--text-muted);
  }

  .resume__plain-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .resume__plain-list li {
    font-size: 12.5px;
    color: var(--text);
    line-height: 1.5;
  }

  @media print {
    .resume__toolbar {
      display: none;
    }
    .resume__doc {
      border: none;
      box-shadow: none;
      padding: 0;
    }
  }
</style>
